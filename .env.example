# FMSS Contracts — production environment
# Copy to .env on the server and fill in. This app is view-only and single-user.

# Port the Node server listens on. Caddy reverse-proxies contracts.fmss.ae here.
PORT=3002

# SQLite file path — MUST be on a persistent disk, NOT inside the app dir
# (the app dir is read-only under the hardened systemd unit). The systemd unit
# grants write access to /data only.
FMSS_DB_PATH=/data/fmss.db

# Authentication: single password for the only user. This app is read-only (no edits);
# only the person with this password can view the data.
# Set this to a strong password you'll remember (it's what you'll type on login).
FMSS_AUTH_PASSWORD=change-me-to-a-strong-password

# Convention only (not currently read by the app).
NODE_ENV=production
